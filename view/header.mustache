<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Master</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/public/css/style.css">
</head>

<body>

<header class="quiz-header">
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid px-4 px-lg-5">

            <a class="navbar-brand d-flex align-items-center" href="/">
                <img src="/public/img/logonav.png" alt="Quiz Master" class="brand-logo">
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarQuiz" aria-controls="navbarQuiz" aria-expanded="false" aria-label="Abrir menú">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarQuiz">
                <ul class="navbar-nav mx-auto align-items-lg-center gap-lg-3 mt-3 mt-lg-0">
                    <li class="nav-item">
                        <a class="nav-link active quiz-nav-pill" href="/">🏠 Inicio</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/ranking">🏆 Ranking</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/preguntas">✏️ Crear pregunta</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="/perfil">👤 Perfil</a>
                    </li>
                </ul>

                <div class="user-box d-flex align-items-center gap-3 mt-3 mt-lg-0">
                    <div class="avatar-circle">D</div>
                    <div class="lh-sm">
                        <div class="fw-bold text-white">{{usuario}}</div>
                        <div class="text-warning fw-bold">{{puntaje}}</div>
                    </div>
                    <a href="/login" class="btn btn-outline-light btn-sm rounded-pill px-3">Ingresar</a>
                </div>
            </div>

        </div>
    </nav>
</header>

<main class="page-content">